# ============================================
# AI Film Studio - API Keys Configuration
# ============================================
# 复制此文件为 api_keys.env 并填入真实值
# cp api_keys.env.example api_keys.env

# --- LLM Provider (DeepSeek / OpenAI 兼容) ---
OPENAI_API_KEY=sk-f347c1c6120140e1b39c8e308b2eb93f
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL_NAME=deepseek-v4-pro

# --- Video Generation ---
KLING_API_KEY=your-kling-api-key
KLING_BASE_URL=https://api.klingai.com/v1

RUNWAY_API_KEY=your-runway-api-key
RUNWAY_BASE_URL=https://api.runwayml.com/v1

PIKA_API_KEY=your-pika-api-key

# --- Image Generation ---
IMAGE_GEN_PROVIDER=openai
# 如果使用 Stable Diffusion 本地部署
SD_BASE_URL=http://localhost:7860

# --- Text-to-Speech (Edge-TTS, 免费无需 Key) ---
# 可选音色见: https://github.com/rany2/edge-tts
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural

# --- Music Generation (可选，默认关闭) ---
# 设为 true 可启用 AI 背景音乐生成，需要 Suno API Key
ENABLE_MUSIC_GENERATION=false
SUNO_API_KEY=your-suno-api-key
SUNO_BASE_URL=https://api.suno.ai/v1

# --- System Configuration ---
# FFmpeg 路径（如果不在 PATH 中）
FFMPEG_PATH=ffmpeg

# 输出目录
OUTPUT_DIR=./output
TEMP_DIR=./temp

# 最大重试次数
MAX_RETRIES=3

# 质量阈值
QUALITY_THRESHOLD_SCREENPLAY=0.8
QUALITY_THRESHOLD_VISUAL=0.75
QUALITY_THRESHOLD_AUDIO=0.7

# 服务端口
API_HOST=0.0.0.0
API_PORT=8000
